<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/backround">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingTop="16dp"
        android:paddingBottom="120dp">

        <!-- ═══ Header ═══ -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sell Product"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="@color/primary"
            android:letterSpacing="-0.02"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Search or scan to record a sale"
            android:textSize="13sp"
            android:textColor="@color/text_secondary"
            android:layout_marginBottom="24dp" />

        <!-- ═══ Barcode input ═══ -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/sellBarcodeLayout"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            android:hint="Search product or scan barcode..."
            app:startIconDrawable="@android:drawable/ic_menu_search"
            app:startIconTint="@color/text_secondary"
            app:endIconMode="custom"
            app:endIconDrawable="@android:drawable/ic_menu_camera"
            app:endIconTint="@color/primary"
            app:hintTextColor="@color/text_secondary"
            app:boxStrokeColor="@color/primary"
            app:boxBackgroundColor="@color/surface"
            app:boxCornerRadiusTopStart="12dp"
            app:boxCornerRadiusTopEnd="12dp"
            app:boxCornerRadiusBottomStart="12dp"
            app:boxCornerRadiusBottomEnd="12dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/sellBarcodeEditText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="text"
                android:textColor="@color/text_primary" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- ═══ Selected product card — Java controls visibility ═══ -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/sellProductCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            android:visibility="gone"
            app:cardBackgroundColor="@color/surface"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/outline_variant"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <!-- Product image -->
                <ImageView
                    android:id="@+id/sellProductImage"
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:scaleType="centerCrop"
                    android:src="@drawable/bg_image_placeholder" />

                <!-- Purple left accent bar -->
                <View
                    android:layout_width="4dp"
                    android:layout_height="match_parent"
                    android:background="@color/primary" />

                <!-- Product info -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:padding="14dp"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/sellProductName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Product Name"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/primary" />

                    <TextView
                        android:id="@+id/sellProductStock"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Stock: 0"
                        android:textSize="12sp"
                        android:textColor="@color/text_secondary" />

                    <!-- ✅ ONE sellProductPrice ID — Java sets this -->
                    <TextView
                        android:id="@+id/sellProductPrice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="₹0.00 / unit"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary" />

                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ═══ Quantity card — stepper + manual text entry ═══ -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="@color/surface"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/outline_variant"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Quantity to Sell"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@color/primary"
                    android:layout_marginBottom="14dp" />

                <!-- Stepper row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@color/backround"
                    android:padding="10dp">

                    <!-- Minus button — wire in Java with click listener -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/sellMinusButton"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:text="−"
                        android:textSize="22sp"
                        android:textColor="@color/primary"
                        android:backgroundTint="@color/outline_variant"
                        android:minWidth="0dp"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:paddingHorizontal="0dp"
                        app:cornerRadius="10dp" />

                    <!-- Editable quantity field — Java reads this value -->
                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginHorizontal="10dp"
                        app:boxStrokeColor="@color/outline_variant"
                        app:boxBackgroundColor="@color/backround"
                        app:boxCornerRadiusTopStart="10dp"
                        app:boxCornerRadiusTopEnd="10dp"
                        app:boxCornerRadiusBottomStart="10dp"
                        app:boxCornerRadiusBottomEnd="10dp">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/sellQuantityEditText"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="number"
                            android:text="1"
                            android:gravity="center"
                            android:textSize="26sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_primary" />

                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Plus button — wire in Java with click listener -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/sellPlusButton"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:text="+"
                        android:textSize="22sp"
                        android:textColor="@color/backround"
                        android:backgroundTint="@color/primary"
                        android:minWidth="0dp"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:paddingHorizontal="0dp"
                        app:cornerRadius="10dp" />

                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ═══ Price summary card ═══ -->
        <!-- sellTotalPrice → Java updates this when quantity changes -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="28dp"
            app:cardBackgroundColor="@color/surface"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/outline_variant"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <View
                    android:layout_width="4dp"
                    android:layout_height="match_parent"
                    android:background="@color/primary" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="PRICE SUMMARY"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_secondary"
                        android:letterSpacing="0.1"
                        android:layout_marginBottom="16dp" />

                    <!-- Unit price row — static label, value mirrors sellProductPrice display -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="10dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Unit Price"
                            android:textSize="13sp"
                            android:textColor="@color/text_secondary" />

                        <!-- No ID — populated same time as sellProductPrice by Java
                             OR make this a separate ID if Java sets it independently -->
                        <TextView
                            android:id="@+id/sellUnitPriceDisplay"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="₹0.00"
                            android:textSize="13sp"
                            android:textColor="@color/text_primary"
                            android:textStyle="bold" />

                    </LinearLayout>

                    <!-- Quantity row — static, mirrors what user typed -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="16dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Quantity"
                            android:textSize="13sp"
                            android:textColor="@color/text_secondary" />

                        <TextView
                            android:id="@+id/sellQuantityDisplay"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="1 unit"
                            android:textSize="13sp"
                            android:textColor="@color/text_primary"
                            android:textStyle="bold" />

                    </LinearLayout>

                    <!-- Divider -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/outline_variant"
                        android:layout_marginBottom="16dp" />

                    <!-- Total row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Total"
                            android:textSize="16sp"
                            android:textColor="@color/text_primary"
                            android:textStyle="bold" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="end">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="PAYABLE"
                                android:textSize="9sp"
                                android:textColor="@color/primary"
                                android:textStyle="bold"
                                android:letterSpacing="0.1" />

                            <!-- ✅ Java updates this: qty × unit price -->
                            <TextView
                                android:id="@+id/sellTotalPrice"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="₹0.00"
                                android:textSize="28sp"
                                android:textStyle="bold"
                                android:textColor="@color/primary" />

                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ═══ Confirm button ═══ -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/confirmSellButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Complete Sale"
            android:textColor="@color/backround"
            android:textSize="15sp"
            android:textStyle="bold"
            android:backgroundTint="@color/primary"
            android:enabled="false"
            app:icon="@android:drawable/checkbox_on_background"
            app:iconTint="@color/backround"
            app:cornerRadius="12dp" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>