<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/backround">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingTop="16dp"
        android:paddingBottom="120dp">

        <!-- ═══ Editorial header ═══ -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Restock Product"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="@color/primary"
            android:letterSpacing="-0.02"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Increase inventory for your essential items"
            android:textSize="13sp"
            android:textColor="@color/text_secondary"
            android:layout_marginBottom="24dp" />

        <!-- ═══ Barcode / search input ═══ -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/restockBarcodeLayout"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            android:hint="Scan or Enter Barcode"
            app:startIconDrawable="@android:drawable/ic_menu_search"
            app:startIconTint="@color/text_secondary"
            app:endIconMode="custom"
            app:endIconDrawable="@android:drawable/ic_menu_camera"
            app:endIconTint="@color/primary"
            app:hintTextColor="@color/text_secondary"
            app:boxStrokeColor="@color/primary"
            app:boxBackgroundColor="@color/surface"
            app:boxCornerRadiusTopStart="12dp"
            app:boxCornerRadiusTopEnd="12dp"
            app:boxCornerRadiusBottomStart="12dp"
            app:boxCornerRadiusBottomEnd="12dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/restockBarcodeEditText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="text"
                android:textColor="@color/text_primary" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- ═══ Selected product card — Java sets visibility ═══ -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/restockProductCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            android:visibility="gone"
            app:cardBackgroundColor="@color/surface"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/outline_variant"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="14dp"
                android:gravity="center_vertical">

                <!-- Product image — rounded square -->
                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/restockProductImage"
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:scaleType="centerCrop"
                    android:src="@drawable/bg_image_placeholder"
                    android:layout_marginEnd="14dp"
                    app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.App.CornerSize50Percent" />

                <!-- Info -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/restockProductName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Product Name"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary" />

                    <TextView
                        android:id="@+id/restockProductStock"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Current Stock: 0"
                        android:textSize="12sp"
                        android:textColor="@color/text_secondary" />

                    <TextView
                        android:id="@+id/restockProductPrice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="₹0.00 / unit"
                        android:textSize="12sp"
                        android:textColor="@color/text_secondary" />

                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ═══ Quantity stepper card ═══ -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="@color/surface"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/outline_variant"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Stock Increment"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@color/primary"
                    android:layout_marginBottom="14dp" />

                <!-- Stepper row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@color/backround"
                    android:padding="10dp">

                    <!-- Minus -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/restockMinusButton"
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        android:text="−"
                        android:textSize="24sp"
                        android:textColor="@color/text_primary"
                        android:backgroundTint="@color/outline_variant"
                        android:minWidth="0dp"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:paddingHorizontal="0dp"
                        app:cornerRadius="10dp" />

                    <!-- Quantity display -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:layout_marginHorizontal="12dp">

                        <com.google.android.material.textfield.TextInputLayout
                            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            app:boxStrokeColor="@color/outline_variant"
                            app:boxBackgroundColor="@color/backround"
                            app:boxCornerRadiusTopStart="10dp"
                            app:boxCornerRadiusTopEnd="10dp"
                            app:boxCornerRadiusBottomStart="10dp"
                            app:boxCornerRadiusBottomEnd="10dp">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/restockQuantityEditText"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="numberDecimal"
                                android:text="10"
                                android:gravity="center"
                                android:textSize="30sp"
                                android:textStyle="bold"
                                android:textColor="@color/text_primary" />

                        </com.google.android.material.textfield.TextInputLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="UNITS"
                            android:textSize="9sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_secondary"
                            android:letterSpacing="0.1" />

                    </LinearLayout>

                    <!-- Plus -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/restockPlusButton"
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        android:text="+"
                        android:textSize="24sp"
                        android:textColor="@color/backround"
                        android:backgroundTint="@color/primary"
                        android:minWidth="0dp"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:paddingHorizontal="0dp"
                        app:cornerRadius="10dp" />

                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>


        <!-- ═══ Update summary card ═══ -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            app:cardBackgroundColor="@color/surface"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/primary"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <!-- Purple left accent -->
                <View
                    android:layout_width="4dp"
                    android:layout_height="match_parent"
                    android:background="@color/primary" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Update Summary"
                            android:textSize="11sp"
                            android:textColor="@color/text_secondary" />

                        <TextView
                            android:id="@+id/restockAddingSummary"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="Adding: 0 pcs"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_primary" />

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="end">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="New Inventory"
                            android:textSize="11sp"
                            android:textColor="@color/text_secondary" />

                        <TextView
                            android:id="@+id/restockNewTotal"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="0 units"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="@color/primary" />

                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ═══ Confirm restock button ═══ -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/confirmRestockButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Add to Stock"
            android:textColor="@color/backround"
            android:textSize="15sp"
            android:textStyle="bold"
            android:backgroundTint="@color/primary"
            android:enabled="false"
            app:icon="@android:drawable/ic_input_add"
            app:iconTint="@color/backround"
            app:cornerRadius="12dp" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>