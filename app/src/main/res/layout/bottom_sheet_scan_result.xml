<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/surface"
    android:paddingBottom="24dp">

    <!-- ═══ Drag handle ═══ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:paddingTop="12dp"
        android:paddingBottom="8dp">

        <View
            android:layout_width="40dp"
            android:layout_height="4dp"
            android:background="@color/outline_variant" />

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="20dp">

        <!-- ═══ "Product Found" header ═══ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="20dp">

            <!-- Green check circle -->
            <LinearLayout
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:gravity="center"
                android:background="@drawable/bg_badge_green"
                android:layout_marginEnd="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✓"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/success" />

            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Product Found"
                android:textSize="19sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary" />

        </LinearLayout>

        <!-- ═══ Product detail card ═══ -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            app:cardBackgroundColor="@color/outline_variant"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/outline_variant"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <!-- Purple left accent bar -->
                <View
                    android:layout_width="4dp"
                    android:layout_height="match_parent"
                    android:background="@color/primary" />

                <!-- Product image -->
                <ImageView
                    android:id="@+id/ivProductImage"
                    android:layout_width="96dp"
                    android:layout_height="96dp"
                    android:scaleType="centerCrop"
                    android:src="@drawable/bg_image_placeholder" />

                <!-- Info -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:padding="14dp"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/tvProductName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Product Name"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"
                        android:layout_marginBottom="4dp" />

                    <!-- Price row -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="8dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="₹"
                            android:textSize="11sp"
                            android:textColor="@color/text_secondary" />

                        <TextView
                            android:id="@+id/tvPrice"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0.00"
                            android:textSize="22sp"
                            android:textStyle="bold"
                            android:textColor="@color/primary"
                            android:layout_marginStart="2dp" />

                        <TextView
                            android:id="@+id/tvCategory"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="/ unit"
                            android:textSize="12sp"
                            android:textColor="@color/text_secondary"
                            android:layout_marginStart="6dp" />

                    </LinearLayout>

                    <!-- Stock badge -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="4dp"
                        android:background="@drawable/bg_badge_green">

                        <View
                            android:layout_width="6dp"
                            android:layout_height="6dp"
                            android:background="@drawable/bg_fab"
                            android:layout_marginEnd="6dp" />

                        <TextView
                            android:id="@+id/tvStock"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="In Stock"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:textColor="@color/success"
                            android:letterSpacing="0.08" />

                    </LinearLayout>

                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ═══ Action buttons ═══ -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSell"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginBottom="12dp"
            android:text="Sell Product"
            android:textColor="@color/backround"
            android:textSize="15sp"
            android:textStyle="bold"
            android:backgroundTint="@color/primary"
            app:icon="@android:drawable/ic_menu_send"
            app:iconTint="@color/backround"
            app:cornerRadius="12dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRestock"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginBottom="16dp"
            android:text="Restock Product"
            android:textColor="@color/primary"
            android:textSize="15sp"
            android:textStyle="bold"
            app:strokeColor="@color/outline_variant"
            app:strokeWidth="2dp"
            app:icon="@android:drawable/ic_input_add"
            app:iconTint="@color/primary"
            app:cornerRadius="12dp" />

        <!-- ═══ View details link ═══ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvViewDetails"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="View Full Details"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/primary"
                android:paddingVertical="8dp" />

        </LinearLayout>

    </LinearLayout>
</LinearLayout>