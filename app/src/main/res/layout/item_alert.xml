<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardBackgroundColor="@color/surface"
    app:cardCornerRadius="12dp"
    app:cardElevation="0dp"
    app:strokeColor="@color/outline_variant"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <!-- Left accent bar — amber for warning, red for out-of-stock
             Java can call setBackgroundColor on this view for critical items -->
        <View
            android:id="@+id/alertAccentBar"
            android:layout_width="4dp"
            android:layout_height="match_parent"
            android:background="@color/warning" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="14dp">

            <!-- Top row: image + name + stock -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/alertProductImage"
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:scaleType="centerCrop"
                    android:src="@drawable/bg_image_placeholder"
                    android:layout_marginEnd="14dp"
                    app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Full"
                    app:strokeColor="@color/outline_variant"
                    app:strokeWidth="1dp" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/alertProductName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Product Name"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary" />

                    <TextView
                        android:id="@+id/alertCurrentStock"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="3dp"
                        android:text="⚠ Only 2 left"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="@color/warning" />

                </LinearLayout>

                <!-- Restock button top-right -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/alertRestockButton"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="Restock"
                    android:textColor="@color/backround"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:backgroundTint="@color/primary"
                    android:minWidth="0dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:paddingHorizontal="14dp"
                    app:cornerRadius="8dp" />

            </LinearLayout>

            <!-- Suggestion text -->
            <TextView
                android:id="@+id/alertSuggestedRestock"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="Suggest restocking 15 units (7-day buffer)"
                android:textSize="12sp"
                android:textColor="@color/text_secondary" />

        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>