<?xml version="1.0" encoding="utf-8"?>
<!-- item_low_stock_alert.xml -->
<!-- Used in DashboardFragment: inflate into lowStockContainer -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:padding="14dp"
    android:layout_marginBottom="8dp"
    android:background="@drawable/bg_low_stock_item"
    android:elevation="2dp">

    <!-- Product Image -->
    <ImageView
        android:id="@+id/productImage"
        android:layout_width="52dp"
        android:layout_height="52dp"
        android:scaleType="centerCrop"
        android:background="@drawable/bg_image_placeholder"
        android:src="@drawable/ic_image_placeholder"/>

    <!-- Product Info -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginHorizontal="12dp">

        <TextView
            android:id="@+id/productName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Product Name"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#F1F0FF"
            android:maxLines="1"
            android:ellipsize="end"/>

        <TextView
            android:id="@+id/productMeta"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Category • N units left"
            android:textSize="11sp"
            android:textColor="#9CA3AF"
            android:layout_marginTop="2dp"/>

    </LinearLayout>

    <!-- Restock Button -->
    <Button
        android:id="@+id/restockBtn"
        android:layout_width="wrap_content"
        android:layout_height="36dp"
        android:text="Restock"
        android:textColor="#1C1B2E"
        android:textSize="12sp"
        android:textStyle="bold"
        android:background="@drawable/bg_btn_amber"
        android:paddingHorizontal="14dp"
        android:stateListAnimator="@null"/>

</LinearLayout>