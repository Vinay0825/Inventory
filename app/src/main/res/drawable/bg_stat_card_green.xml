<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#1C1B2E"/>
            <corners android:radius="16dp"/>
            <stroke android:width="1dp" android:color="#2A2940"/>
        </shape>
    </item>
    <item android:right="0dp" android:top="0dp" android:bottom="0dp" android:width="4dp">
        <shape android:shape="rectangle">
            <solid android:color="#22C55E"/>
            <corners android:topLeftRadius="16dp" android:bottomLeftRadius="16dp"/>
        </shape>
    </item>
</layer-list>